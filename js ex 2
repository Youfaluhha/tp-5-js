let nombreSecret = Math.floor(Math.random() * 10) + 1;
let tentative = 0;
let proposition;

while (proposition != nombreSecret) {

    proposition = prompt("Devinez un nombre entre 1 et 10 :");
    proposition = Number(proposition);
    tentative++;

    if (proposition < nombreSecret) {
        alert("Plus grand !");
    } else if (proposition > nombreSecret) {
        alert("Plus petit !");
    } else {
        alert("Bravo ! Trouvé en " + tentative + " tentatives");
    }
}
